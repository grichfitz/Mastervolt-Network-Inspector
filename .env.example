# -----------------------------------------------------------------------------
# Snapshot ingestion via Supabase API (no direct PostgreSQL sockets)
# Copy to .env and fill values. Never commit real secrets.
# -----------------------------------------------------------------------------

# Supabase project URL (Settings -> API -> Project URL)
SUPABASE_URL=

# Supabase service role key (Settings -> API -> service_role)
# Needed for trusted server-side ingestion/upserts.
SUPABASE_SERVICE_ROLE_KEY=

# Optional app runtime keys (not required by snapshot_ingest.py)
# SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Next.js frontend data access (anon/public only)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Dev/testing fallback: load from local JSONL instead of Supabase when true.
NEXT_PUBLIC_USE_JSONL_FALLBACK=false
